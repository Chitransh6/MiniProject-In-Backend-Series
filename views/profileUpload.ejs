<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class = "w-full min-h-screen bg-zinc-900 p-10 ">
        <h1 class = "text-blue-600 text-3xl p-5">Upload Profile Picture</h1>
        <form action="/profileupload" method = "post" enctype="multipart/form-data">

            <input class = "px-4 py-2 outline-none text-white bg-transparent rounded-lg border-2 m-2" type="file" name = "image" placeholder = "username" required>

           
            <input class = "bg-blue-500 m-2 px-4 py-2 text-white rounded-lg" type="submit"  value = "Submit File">

        </form>
    </div>
</body>
</html>