<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class = "flex justify-between w-full min-h-screen bg-zinc-800 p-8">
        

        <form class = "p-10 flex flex-col gap-4 text-white" action="/edit/<%=post._id%>" method = "post">

        <textarea class = "outline-none rounded-lg p-2 align-top w-70 h-20 resize-none bg-zinc-600 border-2 border-zinc-600 text-zinc-300" readonly><%=post.content%></textarea>

        <textarea class = "outline-none rounded-lg p-2 w-70 h-20 resize-none bg-zinc-600 text-white border-2 border-zinc-600" placeholder="write something" name = "textarea"></textarea>

        <input class="bg-blue-500 py-2 rounded-lg w-30 text-xl " type = "submit" value = "Save Edit">

        </form>

        <a class = "bg-red-500 rounded-lg px-4 py-2 h-fit text-white"href="/logout">logout</a>
    </div>
</body>
</html>