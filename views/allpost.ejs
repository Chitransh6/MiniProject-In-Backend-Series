<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class = "w-full min-h-screen bg-zinc-900 p-10">
     <div class = "w-full flex justify-between">
    <h1 class = "text-white text-2xl">All Posts</h1>
    <a class = "bg-blue-700 p-2 rounded-lg text-white hover:bg-blue-500" href="/logout">Log Out</a>
    </div>
    <div class = "bg-blue-700 p-2 text-center text-white rounded-lg absolute left-270 top-10 hover:bg-blue-500">
        <a  href="/profile">Profile</a>
    </div>

    <div class = "flex flex-wrap gap-2 w-full h-100 mt-7 p-2">
       <% if(posts && posts.length > 0){ %>

                <%posts.forEach(post => { %>
      
                     <div class= "flex flex-col ml-5 w-80 break-words text-wrap p-2 px-4 rounded-lg border-zinc-800 border-1 bg-zinc-800">

                    <h3 class = "text-blue-500">@<%=post.user.username%></h3>

                    <p class = "text-zinc-300 mt-2 text-wrap"><%=post.content%></p>
         
                <div class = "flex gap-4 ">

         <a class = "text-blue-400 rounded-lg mt-4" href="/likes/<%=post._id%>" > <%=post.likes.length%> <%= post.likes.indexOf(post.user._id) ? "like" : "Unlike" %></a>
       
         </div>

         </div>

              <%  }); %>

               
     <%  } %>
    </div>
</body>
</html>